<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Protocol | <%= user.name %></title>

    <style>
        :root {
            --primary: #00f2ff;
            --admin-red: #ff3e3e;
            --bg: #050505;
            --glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }

        body {
            background-color: var(--bg);
            color: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
            overflow-x: hidden;
        }

        #particles { position: fixed; top: 0; left: 0; z-index: 0; opacity: 0.3; pointer-events: none; }
        #cursor-blur {
            position: fixed; width: 500px; height: 500px;
            background: radial-gradient(circle, rgba(255, 62, 62, 0.08) 0%, transparent 70%);
            border-radius: 50%; pointer-events: none; z-index: 1; transform: translate(-50%, -50%);
        }

        .stats-container {
            position: relative; z-index: 10;
            display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px; width: 100%; max-width: 900px; margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--glass);
            border: 1px solid var(--glass-border);
            padding: 20px; border-radius: 20px;
            backdrop-filter: blur(10px);
        }

        .stat-label { color: #666; font-size: 0.75rem; text-transform: uppercase; }
        .stat-value { font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-top: 5px; }

        .action-bar {
            position: relative; z-index: 10;
            width: 100%; max-width: 900px;
            margin-bottom: 1.5rem;
            display: flex; gap: 15px;
        }

        #userSearch {
            flex: 1;
            background: var(--glass);
            border: 1px solid var(--glass-border);
            padding: 15px 25px;
            border-radius: 15px;
            color: white;
            outline: none;
        }

        .management-card {
            position: relative; z-index: 10;
            background: var(--glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            width: 100%; max-width: 900px;
            padding: 1rem;
        }

        .user-table { width: 100%; border-collapse: collapse; }
        .user-table th { padding: 15px; color: #555; font-size: 0.75rem; text-transform: uppercase; }
        .user-table td { padding: 18px 15px; border-bottom: 1px solid rgba(255,255,255,0.03); }

        .btn-delete {
            background: rgba(255, 62, 62, 0.1);
            color: var(--admin-red);
            border: 1px solid rgba(255, 62, 62, 0.2);
            padding: 8px 14px; border-radius: 8px;
            cursor: pointer;
        }

        .btn-edit {
            background: rgba(0,242,255,0.1);
            color: #00f2ff;
            border: 1px solid #00f2ff;
            padding: 8px 14px;
            border-radius: 8px;
            margin-left: 10px;
            cursor: pointer;
        }

        .logout-link {
            margin-top: 2rem;
            color: #555;
            text-decoration: none;
        }
    </style>
</head>

<body>

<canvas id="particles"></canvas>
<div id="cursor-blur"></div>

<div class="stats-container">
    <div class="stat-card">
        <div class="stat-label">Total Users</div>
        <div class="stat-value"><%= users.length %></div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Admin</div>
        <div class="stat-value"><%= user.name %></div>
    </div>
</div>

<div class="action-bar">
    <input type="text" id="userSearch" placeholder="Search..." onkeyup="filterUsers()">
</div>

<main class="management-card">
    <table class="user-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th style="text-align:right;">Actions</th>
            </tr>
        </thead>

        <tbody>
            <% users.forEach(u => { %>
            <tr class="user-row">
                <td class="search-name"><%= u.name %></td>
                <td class="search-email"><%= u.email %></td>

                <td style="text-align:right;">
                    <button class="btn-delete" onclick="deleteUser('<%= u._id %>')">
                        Delete
                    </button>

                    <button class="btn-edit" onclick="editUser('<%= u._id %>', '<%= u.name %>', '<%= u.email %>')">
                        Edit
                    </button>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</main>

<a href="/logout" class="logout-link">Logout</a>

<script>
async function deleteUser(id) {
    if (!confirm("Delete this user?")) return;

    await fetch(`/api/admin/users/${id}`, {
        method: "DELETE",
        credentials: "same-origin"
    });

    location.reload();
}

async function editUser(id, name, email) {
    const newName = prompt("Enter name", name);
    const newEmail = prompt("Enter email", email);

    if (!newName || !newEmail) return;

    await fetch(`/api/admin/users/${id}`, {
        method: "PUT",
        headers: {
            "Content-Type": "application/json"
        },
        credentials: "same-origin",
        body: JSON.stringify({ name: newName, email: newEmail })
    });

    location.reload();
}
</script>
</body>
</html>