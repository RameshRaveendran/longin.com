<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clean Dashboard</title>
<style>
:root{
  --primary:#00f2ff;
  --accent:#7000ff;
  --bg:#050505;
  --glass:rgba(255,255,255,0.05);
}

*{margin:0;padding:0;box-sizing:border-box;font-family:Inter,sans-serif}

body{
  background:var(--bg);
  color:white;
}

.main{
  max-width:900px;
  margin:0 auto;
  padding:2rem;
}

/* HEADER */
.header{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:2rem;
}

.avatar{
  width:60px;
  height:60px;
  background:linear-gradient(135deg,var(--primary),var(--accent));
  border-radius:18px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-weight:800;
  font-size:1.3rem;
}

.user-box{
  display:flex;
  align-items:center;
  gap:1rem;
}

/* SESSION CARD */
.session{
  background:var(--glass);
  padding:2rem;
  border-radius:20px;
  border:1px solid rgba(255,255,255,0.08);
}

.session h2{
  margin-bottom:1rem;
}

.row{
  display:flex;
  justify-content:space-between;
  padding:12px 0;
  border-bottom:1px solid rgba(255,255,255,0.05);
}

.row:last-child{border:none}

.logout{
  margin-top:1.5rem;
  display:inline-block;
  padding:14px 20px;
  background:white;
  color:black;
  border-radius:12px;
  text-decoration:none;
  font-weight:700;
  transition:0.3s;
}

.logout:hover{
  opacity:0.85;
}
</style>
</head>
<body>

<div class="main">

  <!-- HEADER -->
  <div class="header">
    <h1>Welcome</h1>

    <div class="user-box">
      <div class="avatar"><%= user.name.charAt(0) %></div>
      <div>
        <div><%= user.name %></div>
        <small><%= user.email %></small>
      </div>
    </div>
  </div>

  <!-- SESSION DETAILS -->
  <div class="session">
    <h2>Account Details</h2>

    <div class="row">
      <span>Name</span>
      <span><%= user.name %></span>
    </div>

    <div class="row">
      <span>Email</span>
      <span><%= user.email %></span>
    </div>

    <div class="row">
      <span>Role</span>
      <span style="color:var(--primary)"><%= user.role %></span>
    </div>

    <div class="row">
      <span>Status</span>
      <span style="color:var(--primary)">Active</span>
    </div>

    <a href="/logout" class="logout">Logout</a>
  </div>

</div>

</body>
</html>