<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AuthOS | Dashboard</title>
    <style>
        :root {
            --primary: #00f2ff;
            --accent: #7000ff;
            --bg: #050505;
            --glass: rgba(255, 255, 255, 0.03);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }

        body {
            background-color: var(--bg);
            color: white;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            perspective: 1000px;
        }

        /* Animated Particle Background */
        #particles {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: 0;
            opacity: 0.4;
        }

        /* Floating Glow */
        #cursor-blur {
            position: fixed;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(0, 242, 255, 0.08) 0%, rgba(112, 0, 255, 0.03) 50%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 1;
            transform: translate(-50%, -50%);
            transition: all 0.1s ease-out;
        }

        /* The Main Dashboard Card */
        .glass-panel {
            position: relative;
            z-index: 10;
            background: var(--glass);
            backdrop-filter: blur(30px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 40px;
            padding: 4rem 3rem;
            width: 90%;
            max-width: 480px;
            text-align: center;
            box-shadow: 0 50px 100px rgba(0,0,0,0.8);
            animation: slideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .user-header { margin-bottom: 2rem; }

        .initials-circle {
            width: 100px; height: 100px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            border-radius: 30px; /* Squircle shape */
            margin: 0 auto 1.5rem;
            display: flex; align-items: center; justify-content: center;
            font-size: 2.5rem; font-weight: 800;
            transform: rotate(-5deg);
            box-shadow: 0 15px 35px rgba(0, 242, 255, 0.2);
        }

        .greeting { color: var(--primary); font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; }
        
        h1 { font-size: 2.5rem; margin: 0.5rem 0; font-weight: 800; letter-spacing: -1.5px; }

        .data-stack {
            background: rgba(0,0,0,0.3);
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            border: 1px solid rgba(255,255,255,0.05);
        }

        .data-row {
            display: flex; justify-content: space-between; padding: 10px 0;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }
        .data-row:last-child { border: none; }
        .data-label { color: #666; font-size: 0.85rem; }
        .data-value { font-weight: 600; color: #ddd; }

        .logout-btn {
            display: block;
            width: 100%;
            padding: 18px;
            background: white;
            color: black;
            text-decoration: none;
            border-radius: 18px;
            font-weight: 700;
            transition: 0.3s;
        }

        .logout-btn:hover {
            transform: scale(1.03);
            box-shadow: 0 10px 30px rgba(255,255,255,0.2);
            background: #f0f0f0;
        }
    </style>
</head>
<body>

    <canvas id="particles"></canvas>
    <div id="cursor-blur"></div>

    <div class="glass-panel">
        <div class="user-header">
            <div class="initials-circle"><%= user.name.charAt(0) %></div>
            <span class="greeting" id="time-greet">Welcome Back</span>
            <h1><%= user.name %></h1>
        </div>

        <div class="data-stack">
            <div class="data-row">
                <span class="data-label">Identity</span>
                <span class="data-value"><%= user.email %></span>
            </div>
            <div class="data-row">
                <span class="data-label">Access Level</span>
                <span class="data-value" style="color: var(--primary);"><%= user.role %></span>
            </div>
        </div>

        <a href="/logout" class="logout-btn">Terminate Session</a>
    </div>

    <script>
        // 1. Dynamic Greeting
        const hours = new Date().getHours();
        const greetElement = document.getElementById('time-greet');
        if (hours < 12) greetElement.innerText = "Good Morning";
        else if (hours < 18) greetElement.innerText = "Good Afternoon";
        else greetElement.innerText = "Good Evening";

        // 2. Mouse Glow Follower
        const blur = document.getElementById('cursor-blur');
        document.addEventListener('mousemove', (e) => {
            blur.style.left = e.clientX + 'px';
            blur.style.top = e.clientY + 'px';
        });

        // 3. Subtle Particle Background
        const canvas = document.getElementById('particles');
        const ctx = canvas.getContext('2d');
        let particles = [];

        function init() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            for(let i=0; i<60; i++) {
                particles.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    size: Math.random() * 2,
                    speed: Math.random() * 0.5 + 0.2
                });
            }
        }

        function animate() {
            ctx.clearRect(0,0,canvas.width, canvas.height);
            ctx.fillStyle = "white";
            particles.forEach(p => {
                p.y -= p.speed;
                if(p.y < 0) p.y = canvas.height;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.size, 0, Math.PI*2);
                ctx.fill();
            });
            requestAnimationFrame(animate);
        }
        init(); animate();
    </script>
</body>
</html>