<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AuthOS | Dashboard</title>
<style>
:root {
    --primary: #00f2ff;
    --accent: #7000ff;
    --bg: #050505;
    --glass: rgba(255, 255, 255, 0.03);
}

* { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; }

body {
    background-color: var(--bg);
    color: white;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.glass-panel {
    position: relative;
    z-index: 10;
    background: var(--glass);
    backdrop-filter: blur(30px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 40px;
    padding: 4rem 3rem;
    width: 90%;
    max-width: 500px;
    text-align: center;
    box-shadow: 0 50px 100px rgba(0,0,0,0.8);
}

.user-header { margin-bottom: 2rem; }

.initials-circle {
    width: 100px; height: 100px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    border-radius: 30px;
    margin: 0 auto 1.5rem;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.5rem; font-weight: 800;
}

.greeting { color: var(--primary); font-size: 0.9rem; font-weight: 600; }

h1 { font-size: 2.5rem; margin: 0.5rem 0; font-weight: 800; }

.data-stack {
    background: rgba(0,0,0,0.3);
    border-radius: 20px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}

.data-row {
    display: flex; justify-content: space-between; padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
}
.data-row:last-child { border: none; }
.data-label { color: #666; font-size: 0.85rem; }
.data-value { font-weight: 600; color: #ddd; }

.logout-btn {
    display: block;
    width: 100%;
    padding: 18px;
    background: white;
    color: black;
    text-decoration: none;
    border-radius: 18px;
    font-weight: 700;
}

.logout-btn:hover {
    transform: scale(1.03);
    background: #f0f0f0;
}
</style>
</head>
<body>

<div class="glass-panel">
    <div class="user-header">
        <div class="initials-circle"><%= user.name.charAt(0) %></div>
        <span class="greeting" id="time-greet">Welcome Back</span>
        <h1><%= user.name %></h1>
    </div>

    <div class="data-stack">
        <div class="data-row">
            <span class="data-label">Identity</span>
            <span class="data-value"><%= user.email %></span>
        </div>
        <div class="data-row">
            <span class="data-label">Access Level</span>
            <span class="data-value" style="color: var(--primary);"><%= user.role %></span>
        </div>
    </div>

    <a href="/logout" class="logout-btn">Terminate Session</a>
</div>

<script>
const hours = new Date().getHours();
const greetElement = document.getElementById('time-greet');
if (hours < 12) greetElement.innerText = "Good Morning";
else if (hours < 18) greetElement.innerText = "Good Afternoon";
else greetElement.innerText = "Good Evening";
</script>

</body>
</html>