<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auth System | Register</title>

    <!-- ✅ SWEETALERT CDN -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-neon: #00f2ff;
            --secondary-neon: #7000ff;
            --bg-color: #080808;
            --input-bg: rgba(255, 255, 255, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: white;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }

        #cursor {
            position: fixed;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(111, 0, 255, 0.404) 0%, rgba(0, 242, 255, 0.05) 50%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 1;
            transform: translate(-50%, -50%);
        }

        .register-card {
            position: relative;
            z-index: 10;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 2.5rem;
            border-radius: 24px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        h2 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
            text-align: center;
            background: linear-gradient(to right, #fff, var(--secondary-neon));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        p.subtitle {
            text-align: center;
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.9rem;
            margin-bottom: 2rem;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        input {
            background: var(--input-bg);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 14px 16px;
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            outline: none;
            transition: all 0.3s ease;
        }

        input:focus {
            border-color: var(--secondary-neon);
            background: rgba(255, 255, 255, 0.08);
            box-shadow: 0 0 15px rgba(112, 0, 255, 0.2);
        }

        button {
            margin-top: 1rem;
            padding: 14px;
            border-radius: 12px;
            border: none;
            background: white;
            color: black;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 255, 255, 0.2);
        }

        .footer-links {
            margin-top: 1.5rem;
            text-align: center;
            font-size: 0.9rem;
        }

        .footer-links a {
            color: var(--primary-neon);
            text-decoration: none;
            font-weight: 600;
        }

        .footer-links a:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>

    <div id="cursor"></div>

    <div class="register-card">
        <h2>Join Us</h2>
        <p class="subtitle">Create an account to get started.</p>

        <!-- ❌ REMOVE action + method -->
        <form id="registerForm">
            <input type="text" id="name" placeholder="Full Name" />
            <input type="email" id="email" placeholder="Email Address" />
            <input type="password" id="password" placeholder="Create Password" />
            <button type="submit">Create Account</button>
        </form>

        <div class="footer-links">
            <p>Already have an account? <a href="/login">Log in here</a></p>
        </div>
    </div>

    <script>
        const cursor = document.getElementById('cursor');
        document.addEventListener('mousemove', (e) => {
            cursor.style.left = e.clientX + 'px';
            cursor.style.top = e.clientY + 'px';
        });

        // ✅ FORM SUBMIT HANDLER
        document.getElementById('registerForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            try {
                const res = await fetch('/register', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ name, email, password })
                });

                const data = await res.json();

                // ❌ USER EXISTS
                if (data.message === "User already exists" || data.message.includes("duplicate")) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Oops...',
                        text: 'User already exists!'
                    });
                }

                // ❌ VALIDATION ERROR
                else if (data.message.includes("required")) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Missing Fields',
                        text: 'Please fill all fields!'
                    });
                }

                // ✅ SUCCESS
                else {
                    Swal.fire({
                        icon: 'success',
                        title: 'Success',
                        text: 'Account created successfully!'
                    }).then(() => {
                        window.location.href = '/login';
                    });
                }

            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Server Error',
                    text: 'Something went wrong!'
                });
            }
        });

    </script>
</body>

</html>